{
  "name": "mdv2",
  "version": "1.0.0",
  "description": "A CLI presentation tool that displays Markdown files as terminal slides",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mdv2": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.tsx",
    "demo": "tsx src/index.tsx examples/demo.md"
  },
  "keywords": [
    "cli",
    "presentation",
    "markdown",
    "terminal",
    "slides"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-syntax-highlight": "^2.0.2",
    "marked": "^12.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
